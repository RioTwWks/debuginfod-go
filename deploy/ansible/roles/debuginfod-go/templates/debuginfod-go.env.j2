# /etc/debuginfod-go/debuginfod-go.env — managed by Ansible
# Роль: deploy/ansible/roles/debuginfod-go

DEBUGINFOD_DB_PATH=/var/lib/debuginfod-go/debuginfod.sqlite
DEBUGINFOD_SCAN_PATH={{ debuginfod_scan_path }}
DEBUGINFOD_CACHE_DIR=/var/cache/debuginfod-go
DEBUGINFOD_PORT={{ debuginfod_port }}
DEBUGINFOD_RESCAN_INTERVAL={{ debuginfod_rescan_interval }}
DEBUGINFOD_METADATA_MAXTIME=5s
DEBUGINFOD_LOG_LEVEL={{ debuginfod_log_level }}
DEBUGINFOD_LAZY_EXTRACT={{ debuginfod_lazy_extract | lower }}
DEBUGINFOD_UI_ENABLED={{ debuginfod_ui_enabled | lower }}
DEBUGINFOD_SCAN_WORKERS={{ debuginfod_scan_workers }}
DEBUGINFOD_SCAN_ENABLED={{ debuginfod_scan_enabled | lower }}
DEBUGINFOD_METADATA_PAGE_SIZE=100
{% if debuginfod_scan_webhook_url | length > 0 %}
DEBUGINFOD_SCAN_WEBHOOK_URL={{ debuginfod_scan_webhook_url }}
{% endif %}
{% if debuginfod_zabbix_key | length > 0 %}
DEBUGINFOD_ZABBIX_KEY={{ debuginfod_zabbix_key }}
{% endif %}
{% if debuginfod_upstream_urls | length > 0 %}
DEBUGINFOD_URLS={{ debuginfod_upstream_urls }}
{% endif %}
{% if debuginfod_database_url | length > 0 %}
DEBUGINFOD_DATABASE_URL={{ debuginfod_database_url }}
{% endif %}
