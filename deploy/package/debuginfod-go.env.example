# /etc/debuginfod-go/debuginfod-go.env — production defaults
# Полный список: README.md, internal/config/config.go

DEBUGINFOD_DB_PATH=/var/lib/debuginfod-go/debuginfod.sqlite
DEBUGINFOD_SCAN_PATH=/usr/lib/debug
DEBUGINFOD_CACHE_DIR=/var/cache/debuginfod-go
DEBUGINFOD_PORT=8002
DEBUGINFOD_RESCAN_INTERVAL=1h
DEBUGINFOD_METADATA_MAXTIME=5s
DEBUGINFOD_LOG_LEVEL=info
DEBUGINFOD_LAZY_EXTRACT=true
DEBUGINFOD_UI_ENABLED=true
DEBUGINFOD_SCAN_WORKERS=4
DEBUGINFOD_METADATA_PAGE_SIZE=100
# DEBUGINFOD_DATABASE_URL=postgres://user:pass@localhost:5432/debuginfod
# DEBUGINFOD_URLS=http://upstream-debuginfod:8002
# DEBUGINFOD_ZABBIX_KEY=change-me
