# debuginfod-go — Docker Compose (PostgreSQL для тестов)
# cp .env.example .env

# Корпоративный proxy.
# ВАЖНО: для docker pull (postgres:16-alpine) нужен proxy в daemon.json — см. README.md.
# Эти переменные не влияют на docker pull; нужны при сборке других образов с Dockerfile.
# HTTP_PROXY=http://proxy.corp:3128
# HTTPS_PROXY=http://proxy.corp:3128
# NO_PROXY=localhost,127.0.0.1,.corp.local
