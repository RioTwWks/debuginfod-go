# Только Docker Engine 23.0+ (НЕ Astra 1.7 — сломает docker.service).
# На Astra используйте http-proxy.conf.example + systemd (см. README.md).
{
  "proxies": {
    "default": {
      "httpProxy": "http://proxy.corp:3128",
      "httpsProxy": "http://proxy.corp:3128",
      "noProxy": "localhost,127.0.0.1,.corp.local"
    }
  }
}
