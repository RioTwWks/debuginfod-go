# Параметры docker compose build (скопируйте в .env.docker и: export $(cat .env.docker | xargs))
#
# Astra Linux 1.7 — обычно bullseye; при проблемах с glibc попробуйте buster.

# DEBIAN_SUITE=bullseye
# APT_MIRROR=mirror.yandex.ru/debian
# SKIP_APT_INSTALL=false

# Полностью без apt в контейнере (после подготовки базового образа, см. deploy/docker/README.md):
# SKIP_APT_INSTALL=true
