# Параметры docker compose build (скопируйте в .env.docker и: export $(grep -v '^#' .env.docker | xargs))
#
# Корпоративный прокси (обязательно для docker build, если интернет только через proxy):
# HTTP_PROXY=http://proxy.corp:3128
# HTTPS_PROXY=http://proxy.corp:3128
# NO_PROXY=localhost,127.0.0.1,.corp.local
#
# make docker-astra подхватывает /etc/environment через deploy/docker/ensure-proxy-env.sh

# HTTP_PROXY=http://proxy.corp:3128
# HTTPS_PROXY=http://proxy.corp:3128
# NO_PROXY=localhost,127.0.0.1

# Astra Linux 1.7 — make docker-astra (APT_PROFILE=astra по умолчанию в overlay).
# DEBIAN_SUITE=buster
# APT_PROFILE=astra
# APT_MIRROR=mirror.yandex.ru/debian
# SKIP_APT_INSTALL=false

# Если apt падает на Certificate verification failed (корпоративный прокси + debian:slim):
# APT_INSECURE=true

# Полностью без apt в контейнере (после подготовки базового образа, см. deploy/docker/README.md):
# SKIP_APT_INSTALL=true

# PostgreSQL для тестов — deploy/docker-compose/ (см. deploy/docker-compose/README.md)
