{
  "$schema": "https://cursor.com/schemas/mcp.json",
  "mcpServers": {
    "go-doc": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-go-doc"],
      "env": {}
    },
    "sqlite": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sqlite"],
      "env": {
        "SQLITE_DB_PATH": "./debuginfod.sqlite"
      }
    },
    "test-runner": {
      "command": "go",
      "args": ["test", "./..."],
      "env": {}
    },
    "go-quality-local": {
      "command": "npx",
      "args": ["-y", "@afshinator/mcp-server-go-quality"]
    }
  },
  "projectScripts": {
    "test": "make test",
    "vet": "go vet ./...",
    "build": "make build",
    "run": "make run-env",
    "health": "curl -sf http://localhost:8002/healthz",
    "metadata-glob": "curl -s 'http://localhost:8002/metadata?key=glob&value=*'"
  },
  "hints": [
    "Перед изменением storage читай схему в internal/storage/sqlite.go",
    "Тесты buildid требуют gcc для GNU и go build для Go",
    "Архивные тесты RPM пропускаются без rpmbuild",
    "Документация: README.md, DEVELOPMENT.md, TODO.md"
  ]
}
