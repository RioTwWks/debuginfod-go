{
  "$schema": "https://cursor.com/schemas/mcp.json",
  "mcpServers": {
    "go-doc": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-go-doc"],
      "env": {}
    },
    "sqlite": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sqlite"],
      "env": {
        "SQLITE_DB_PATH": "./debuginfod.sqlite"
      }
    },
    "test-runner": {
      "command": "go",
      "args": ["test", "./..."],
      "env": {}
    },
    "go-quality-local": {
      "command": "npx",
      "args": ["-y", "@afshinator/mcp-server-go-quality"]
    }
  },
  "projectScripts": {
    "test": "make test",
    "vet": "go vet ./...",
    "build": "make build",
    "build-find": "make build-find",
    "run": "make run-env",
    "health": "curl -sf http://localhost:8002/healthz",
    "ui": "curl -sf http://localhost:8002/ui/ | head -20",
    "ui-stats": "curl -s http://localhost:8002/ui/api/stats",
    "ui-search": "curl -s 'http://localhost:8002/ui/api/search?q='",
    "zabbix": "curl -s http://localhost:8002/zabbix",
    "metadata-glob": "curl -s 'http://localhost:8002/metadata?key=glob&value=*'",
    "openapi": "curl -s http://localhost:8002/openapi.yaml | head -30"
  },
  "hints": [
    "Схема БД: internal/storage/sqlite.go (artifacts, sources, scanned_files)",
    "Целевые ОС: Astra Linux, Ubuntu (deb), RedOS, CentOS (rpm)",
    "apk/pacman/pkg.tar — НЕ поддерживаются, не добавлять",
    "Архивы: internal/archive/kind.go — DetectKind, isUnsupportedDistroPackage",
    "Lazy extract: DEBUGINFOD_LAZY_EXTRACT=true — archive_path+member_path без file_path",
    "Тесты buildid требуют gcc; RPM — rpmbuild; Go binary — go build",
    "HTTP: /buildid, /metadata, /healthz, /zabbix, /ui/, /openapi.yaml",
    "CLI: cmd/debuginfod-find — debuginfo/executable/source/section/metadata",
    "Security: CORS, rate limit, Basic Auth, TLS/mTLS — internal/webapi/security.go",
    "Документация: README.md, DEVELOPMENT.md, TODO.md, deploy/zabbix/README.md",
    "Конфиг: .env.example + internal/config/config.go",
    "Roadmap: TODO.md — отмечать [x] при завершении задач",
    "Examples: examples/ — docker-compose + GDB demo (make demo)"
  ]
}
