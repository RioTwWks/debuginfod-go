# Пример .env для debuginfod-go
# Приоритет: флаги CLI > env > этот файл
# Полный список: README.md и internal/config/config.go

DEBUGINFOD_DB_PATH=./debuginfod.sqlite
# DEBUGINFOD_DATABASE_URL=postgres://user:pass@localhost:5432/debuginfod
DEBUGINFOD_SCAN_PATH=/usr/lib/debug
# Astra / Ubuntu:  /usr/lib/debug,/var/cache/apt/archives
# RedOS / CentOS:   /usr/lib/debug,/var/cache/dnf
DEBUGINFOD_PORT=8002
DEBUGINFOD_RESCAN_INTERVAL=1h
DEBUGINFOD_METADATA_MAXTIME=5s
DEBUGINFOD_LOG_LEVEL=info
DEBUGINFOD_CACHE_DIR=./.debuginfod-cache
DEBUGINFOD_CACHE_MAX_BYTES=1073741824
DEBUGINFOD_LAZY_EXTRACT=true
DEBUGINFOD_UI_ENABLED=true
DEBUGINFOD_SCAN_WORKERS=8
# Для dedup (xdelta/dwz/objcopy) на ~10 ГБ RAM: 4 воркера, не 8 — иначе рост SWAP.
# DEBUGINFOD_DEDUP_ENABLED=true
# DEBUGINFOD_CORS_ORIGINS=*
# DEBUGINFOD_RATE_LIMIT=10
# DEBUGINFOD_BASIC_AUTH_USER=admin
# DEBUGINFOD_BASIC_AUTH_PASSWORD=secret
# DEBUGINFOD_TLS_CERT=/etc/debuginfod/tls.crt
# DEBUGINFOD_TLS_KEY=/etc/debuginfod/tls.key
# DEBUGINFOD_TLS_CLIENT_CA=/etc/debuginfod/client-ca.pem
DEBUGINFOD_METADATA_PAGE_SIZE=100
# DEBUGINFOD_URLS=http://upstream-debuginfod:8002
DEBUGINFOD_ZABBIX_KEY=change-me
# DEBUGINFOD_ADMIN_KEY=admin-token          # POST /admin/rescan (по умолчанию = ZABBIX_KEY)
# DEBUGINFOD_SCAN_ENABLED=true             # false = read-only реплика без scan
# DEBUGINFOD_SCAN_WEBHOOK_URL=http://hooks.example/scan
# DEBUGINFOD_DEDUP_ENABLED=true
# DEBUGINFOD_DEDUP_PROJECTS=QuikServer,Front
DEBUGINFOD_DEDUP_WORKERS=4
# DEBUGINFOD_DEDUP_STRATEGY=xdelta-decompress-dwz
# DEBUGINFOD_DEDUP_COMPRESS_BASE=true
# DEBUGINFOD_XDELTA_PATH=xdelta3
# DEBUGINFOD_DWZ_PATH=dwz
# DEBUGINFOD_OBJCOPY_PATH=objcopy
DEBUGINFOD_ENV_FILE=.env
